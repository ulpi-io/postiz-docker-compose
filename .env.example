# Public endpoint routed by Coolify
POSTIZ_URL=https://post.con.fyi

# Generate URL-safe values with: openssl rand -hex 32
JWT_SECRET=replace-me
POSTIZ_POSTGRES_PASSWORD=replace-me
POSTIZ_REDIS_PASSWORD=replace-me
TEMPORAL_POSTGRES_PASSWORD=replace-me

POSTIZ_POSTGRES_USER=postiz-user
POSTIZ_POSTGRES_DB=postiz

# Lock registration after creating the first account.
DISABLE_REGISTRATION=false
IS_GENERAL=true
RUN_CRON=true
API_LIMIT=30
FEE_AMOUNT=0.05

# Local persistent uploads are served by the Postiz application.
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# Optional integrations
OPENAI_API_KEY=
X_API_KEY=
X_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
BEEHIIVE_API_KEY=
BEEHIIVE_PUBLICATION_ID=
THREADS_APP_ID=
THREADS_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN_ID=
SLACK_ID=
SLACK_SECRET=
SLACK_SIGNING_SECRET=
MASTODON_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=
NEXT_PUBLIC_DISCORD_SUPPORT=
NEXT_PUBLIC_POLOTNO=
STRIPE_PUBLISHABLE_KEY=
